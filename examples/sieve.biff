let s = [200];
let is_prime = " is prime!\n";

let index = 1;
loop (199) {
  let jump = index + 1;
  let curr = index + jump;
  let a = (200 / jump) - 1;
  loop (a) {
    s[curr] = 1;
    curr = curr + jump;
  }

  index = index + 1;
}

index = 1;
loop (199) {
  if (s[index] == 0) {
    print_val(index + 1);
    print_str(is_prime);
  }

  index = index + 1;
}
